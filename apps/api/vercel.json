{
  "version": 2,
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "cd ../.. && npm install",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "src/vercel/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
